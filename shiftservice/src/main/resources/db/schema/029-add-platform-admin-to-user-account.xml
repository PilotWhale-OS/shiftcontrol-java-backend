<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <changeSet id="029-add-platform-admin-to-user-account" author="codex">
        <addColumn tableName="user_account">
            <column name="platform_admin" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
        </addColumn>

        <createIndex tableName="user_account" indexName="idx_user_account_platform_admin">
            <column name="platform_admin"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
